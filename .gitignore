.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
backend/.pytest-agent-output-writer/
backend/.test-tmp/
backend/pytest-cache-files-*/
node_modules/
dist/
coverage/
*.log
data/transcripts
data/outputs
backend/app/security/
backend/*.local.json


# Local-only transcript material. Keep real/confidential transcripts out of git.
data/sample_transcripts/*
!data/sample_transcripts/README.md
!data/sample_transcripts/synthetic_recruiting_call.txt
data/sample_outputs/*
!data/sample_outputs/README.md

# VPS-local TLS/ACME state. Do not commit private keys or challenge files.
certbot/
infra/nginx/acme/

# Skills: single source of truth lives in /skills (tracked). The per-tool paths
# .claude/skills and .codex/skills are local directory junctions to /skills,
# created with: New-Item -ItemType Junction -Path .claude\skills -Target ..\skills
# Edit skills in /skills only; both tools read the same files through the junctions.
/.claude/skills/
/.codex/skills/
